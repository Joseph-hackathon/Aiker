{
  "rewrites": [
    {
      "source": "/api-lumen/:path*",
      "destination": "https://aiker-agent-lumen-scout.vercel.app/:path*"
    },
    {
      "source": "/api-stripe/:path*",
      "destination": "https://aiker-agent-stripe-settle.vercel.app/:path*"
    },
    {
      "source": "/api-orbit/:path*",
      "destination": "https://aiker-agent-orbit.vercel.app/:path*"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
